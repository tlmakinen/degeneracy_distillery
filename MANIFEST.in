# Include documentation
include README.md
include INSTALL.md
include LICENSE

# Include environment specifications
include degen_env.yml
include degen_env_minimal.yml

# Include configuration files
recursive-include degeneracy_distillery *.yaml
recursive-include degeneracy_distillery *.yml

# Exclude development files
exclude setup.sh
exclude .gitignore
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
